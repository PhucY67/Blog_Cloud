<!DOCTYPE html>
<html lang="vi">

<head>
    <% const title=(profileUser.displayName || profileUser.username) + ' - BlogCloud' ; %>
        <%- include('partials/head', { title: title }) %>
</head>

<body>
    <%- include('partials/header') %>
        <script src="/js/sidebar.js"></script>

        <main class="container my-4" style="margin-top: 80px !important;">
            <div class="row justify-content-end">
                <div class="col-12 col-md-10 col-lg-9 col-xl-10">
                    <div class="card shadow-sm border-0 rounded-4 mb-4">
                        <div class="card-body p-0">
                            <% if (profileUser.background) { %>
                                <div
                                    style="height: 180px; background: url('<%= profileUser.background %>') center/cover; border-radius: 12px 12px 0 0;">
                                </div>
                                <% } else { %>
                                    <div
                                        style="height: 180px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px 12px 0 0;">
                                    </div>
                                    <% } %>
                                        <div class="px-4" style="margin-top: -50px;">
                                            <img src="<%= profileUser.avatar || '/uploads/default-avatar.png' %>"
                                                alt="Avatar"
                                                style="width: 100px; height: 100px; border-radius: 50%; border: 4px solid white; object-fit: cover;">
                                        </div>
                                        <div class="text-center px-4 pb-4">
                                            <h3 class="mt-2">
                                                <%= profileUser.displayName || profileUser.username %>
                                            </h3>
                                            <p class="text-muted">@<%= profileUser.username %>
                                            </p>
                                            <p><span
                                                    class="badge bg-<%= profileUser.role === 'admin' ? 'danger' : 'primary' %>">
                                                    <%= profileUser.role==='admin' ? 'Quản trị viên' : 'Thành viên' %>
                                                </span></p>
                                        </div>
                        </div>
                    </div>
                    <div class="card shadow-sm border-0 rounded-4">
                        <div class="card-header bg-white fw-bold">
                            <i class="fas fa-newspaper me-2"></i>Bài viết của <%= profileUser.displayName ||
                                profileUser.username %>
                        </div>
                        <div class="card-body">
                            <% if (posts && posts.length> 0) { %>
                                <% posts.forEach(post=> { %>
                                    <div class="mb-3 pb-2 border-bottom">
                                        <a href="/posts/<%= post._id %>" class="text-decoration-none fw-semibold fs-5">
                                            <%= post.title %>
                                        </a>
                                        <div class="small text-muted mt-1">
                                            <i class="far fa-calendar-alt"></i>
                                            <%= new Date(post.createdAt).toLocaleDateString('vi-VN') %>
                                                <span class="ms-3"><i class="far fa-heart"></i>
                                                    <%= post.likes ? post.likes.length : 0 %>
                                                </span>
                                                <span class="ms-2"><i class="far fa-comment"></i>
                                                    <%= post.comments ? post.comments.length : 0 %>
                                                </span>
                                        </div>
                                    </div>
                                    <% }) %>
                                        <% } else { %>
                                            <p class="text-muted">
                                                <%= profileUser.displayName || profileUser.username %> chưa có bài viết
                                                    nào.
                                            </p>
                                            <% } %>
                        </div>
                    </div>

                </div>
            </div>
        </main>

        <%- include('partials/footer') %>
</body>

</html>