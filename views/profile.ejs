<!DOCTYPE html>
<html lang="vi">

<head>
  <% const title='Hồ sơ của tôi - BlogCloud' ; %>
    <%- include('partials/head', { title: title }) %>
</head>

<body>
  <%- include('partials/header') %>
    <script src="/js/sidebar.js"></script>

    <main class="container my-4" style="margin-top: 80px !important;">
      <div class="row justify-content-end">
        <div class="col-12 col-md-10 col-lg-9 col-xl-10">
          <div class="card shadow-sm border-0 rounded-4 mb-4">
            <div class="card-body p-0">
              <% if (user.background) { %>
                <div class="profile-background" id="backgroundImg"
                  style="height: 180px; background: url('<%= user.background %>') center/cover; border-radius: 12px 12px 0 0; position: relative;">
                  <% } else { %>
                    <div class="profile-background" id="backgroundImg"
                      style="height: 180px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border-radius: 12px 12px 0 0; position: relative;">
                      <% } %>
                        <button class="btn btn-sm btn-light"
                          style="position: absolute; bottom: 10px; right: 10px; opacity: 0.8;"
                          onclick="document.getElementById('backgroundInput').click()">
                          <i class="fas fa-camera"></i> Đổi ảnh bìa
                        </button>
                    </div>

                    <div class="px-4" style="margin-top: -50px;">
                      <div style="position: relative; display: inline-block;">
                        <img src="<%= user.avatar || '/uploads/default-avatar.png' %>" id="avatarImg" alt="Avatar"
                          style="width: 100px; height: 100px; border-radius: 50%; border: 4px solid white; object-fit: cover;">
                        <button class="btn btn-sm btn-secondary"
                          style="position: absolute; bottom: 5px; right: 0; border-radius: 50%; padding: 2px 6px;"
                          onclick="document.getElementById('avatarInput').click()">
                          <i class="fas fa-camera"></i>
                        </button>
                      </div>
                    </div>

                    <div class="text-center px-4 pb-4">
                      <h3 class="mt-2">
                        <%= user.displayName || user.username %>
                      </h3>
                      <p class="text-muted">@<%= user.username %>
                      </p>
                      <p><span class="badge bg-<%= user.role === 'admin' ? 'danger' : 'primary' %>">
                          <%= user.role==='admin' ? 'Quản trị viên' : 'Thành viên' %>
                        </span></p>
                    </div>
                    <form id="avatarForm" enctype="multipart/form-data" style="display: none;">
                      <input type="file" name="avatar" id="avatarInput" accept="image/*">
                    </form>
                    <form id="backgroundForm" enctype="multipart/form-data" style="display: none;">
                      <input type="file" name="background" id="backgroundInput" accept="image/*">
                    </form>
                </div>
            </div>
            <div class="card shadow-sm border-0 rounded-4">
              <div class="card-header bg-white fw-bold">
                <i class="fas fa-chart-line me-2"></i>Hoạt động
              </div>
              <div class="list-group list-group-flush">
                <a href="#myPosts" class="list-group-item list-group-item-action" data-bs-toggle="collapse">
                  <i class="fas fa-newspaper me-2"></i>Bài viết của tôi
                </a>
                <a href="#myComments" class="list-group-item list-group-item-action" data-bs-toggle="collapse">
                  <i class="fas fa-comments me-2"></i>Bình luận của tôi
                </a>
                <a href="#savedPosts" class="list-group-item list-group-item-action" data-bs-toggle="collapse">
                  <i class="fas fa-bookmark me-2"></i>Bài viết đã lưu
                </a>
              </div>

              <div class="card-body">
                <div id="myPosts" class="collapse show">
                  <h6 class="fw-semibold mb-3">Bài viết của tôi</h6>
                  <% if (myPosts && myPosts.length> 0) { %>
                    <% myPosts.forEach(post=> { %>
                      <div class="mb-3 pb-2 border-bottom d-flex justify-content-between align-items-center">
                        <div>
                          <a href="/posts/<%= post._id %>" class="text-decoration-none fw-semibold">
                            <%= post.title %>
                          </a>
                          <div class="small text-muted">
                            <%= new Date(post.createdAt).toLocaleDateString('vi-VN') %>
                          </div>
                        </div>
                        <div>
                          <a href="/posts/<%= post._id %>/edit" class="btn btn-sm btn-outline-secondary"><i
                              class="fas fa-edit"></i></a>
                          <form action="/posts/<%= post._id %>/delete" method="POST" class="d-inline"
                            onsubmit="return confirm('Xóa vĩnh viễn?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i
                                class="fas fa-trash"></i></button>
                          </form>
                        </div>
                      </div>
                      <% }) %>
                        <% } else { %>
                          <p class="text-muted">Chưa có bài viết nào.</p>
                          <% } %>
                </div>
                <div id="myComments" class="collapse">
                  <h6 class="fw-semibold mt-3 mb-3">Bình luận của tôi</h6>
                  <% if (myComments && myComments.length> 0) { %>
                    <% myComments.forEach(comment=> { %>
                      <div class="mb-2 pb-2 border-bottom">
                        <div>
                          <%= comment.content %>
                        </div>
                        <div class="small text-muted">
                          Trong bài: <a href="/posts/<%= comment.post._id %>">
                            <%= comment.post.title %>
                          </a>
                          - <%= new Date(comment.createdAt).toLocaleString('vi-VN') %>
                        </div>
                      </div>
                      <% }) %>
                        <% } else { %>
                          <p class="text-muted">Chưa có bình luận nào.</p>
                          <% } %>
                </div>
                <div id="savedPosts" class="collapse">
                  <h6 class="fw-semibold mt-3 mb-3">Bài viết đã lưu</h6>
                  <% if (user.savedPosts && user.savedPosts.length> 0) { %>
                    <% user.savedPosts.forEach(post=> { %>
                      <div class="mb-2 pb-2 border-bottom">
                        <a href="/posts/<%= post._id %>">
                          <%= post.title %>
                        </a>
                        <div class="small text-muted">
                          <%= new Date(post.createdAt).toLocaleDateString('vi-VN') %>
                        </div>
                      </div>
                      <% }) %>
                        <% } else { %>
                          <p class="text-muted">Chưa lưu bài viết nào.</p>
                          <% } %>
                </div>
              </div>
            </div>
          </div>
        </div>
    </main>

    <%- include('partials/footer') %>

      <script src="/js/common.js"></script>
      <script>
        document.getElementById('avatarInput').addEventListener('change', async function () {
          const file = this.files[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = (e) => document.getElementById('avatarImg').src = e.target.result;
          reader.readAsDataURL(file);
          const formData = new FormData();
          formData.append('avatar', file);
          try {
            const res = await fetch('/users/me/avatar', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
              showToast('Đã cập nhật avatar!', 'success');
              document.getElementById('avatarImg').src = data.avatar + '?t=' + Date.now();
            } else {
              showToast('Lỗi cập nhật avatar', 'danger');
            }
          } catch (err) {
            showToast('Lỗi kết nối', 'danger');
          }
        });
        document.getElementById('backgroundInput').addEventListener('change', async function () {
          const file = this.files[0];
          if (!file) return;
          const reader = new FileReader();
          reader.onload = (e) => document.getElementById('backgroundImg').style.backgroundImage = `url('${e.target.result}')`;
          reader.readAsDataURL(file);
          const formData = new FormData();
          formData.append('background', file);
          try {
            const res = await fetch('/users/me/background', { method: 'POST', body: formData });
            const data = await res.json();
            if (data.success) {
              showToast('Đã cập nhật background!', 'success');
              document.getElementById('backgroundImg').style.backgroundImage = `url('${data.background}?t=${Date.now()}')`;
            } else {
              showToast('Lỗi cập nhật background', 'danger');
            }
          } catch (err) {
            showToast('Lỗi kết nối', 'danger');
          }
        });
      </script>
</body>
</html>