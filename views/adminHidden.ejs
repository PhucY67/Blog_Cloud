<!DOCTYPE html>
<html lang="vi">
<head>
    <% const title = 'Bài viết đã ẩn - BlogCloud'; %>
    <%- include('partials/head', { title: title }) %>
</head>
<body>
    <%- include('partials/header') %>
    <script src="/js/sidebar.js"></script>
    
    <main class="container my-4" style="margin-top: 80px !important;">
    <div class="row justify-content-end">
      <div class="col-12 col-md-10 col-lg-9 col-xl-10">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-header bg-dark text-white fw-bold d-flex justify-content-between align-items-center">
            <span><i class="fas fa-eye-slash me-2"></i>Bài viết đã ẩn</span>
            <a href="/admin" class="btn btn-sm btn-light"><i class="fas fa-flag"></i> Bài viết bị báo cáo</a>
          </div>
          <div class="card-body">
            <% if (posts && posts.length > 0) { %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Tiêu đề</th>
                    <th>Tác giả</th>
                    <th>Ngày đăng</th>
                    <th>Hành động</th>
                  </tr>
                </thead>
                <tbody>
                  <% posts.forEach(post => { %>
                    <tr>
                      <td><a href="/posts/<%= post._id %>"><%= post.title %></a></td>
                      <td><%= post.author ? post.author.username : 'Unknown' %></td>
                      <td><%= new Date(post.createdAt).toLocaleDateString('vi-VN') %></td>
                      <td>
                        <form action="/admin/unhide/<%= post._id %>" method="POST" class="d-inline" onsubmit="return confirm('Bỏ ẩn bài viết này?')">
                          <button type="submit" class="btn btn-sm btn-success"><i class="fas fa-eye"></i> Bỏ ẩn</button>
                        </form>
                        <form action="/posts/<%= post._id %>/delete" method="POST" class="d-inline" onsubmit="return confirm('Xóa vĩnh viễn?')">
                          <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i> Xóa</button>
                        </form>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <% } else { %>
              <p class="text-muted text-center">Không có bài viết nào bị ẩn.</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </main>

  <%- include('partials/footer') %>
</body>
</html>