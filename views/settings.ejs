<!DOCTYPE html>
<html lang="vi">
<head>
    <% const title = 'Cài đặt - BlogCloud'; %>
    <%- include('partials/head', { title: title }) %>
  <style>
    .settings-section { margin-bottom: 30px; padding-bottom: 20px; border-bottom: 1px solid #ddd; }
    .settings-section h5 { margin-bottom: 15px; }
  </style>
</head>

<body> 
    <%- include('partials/header') %>
    <script src="/js/sidebar.js"></script>
  <button class="menu-toggle" id="menuToggle"><i class="fas fa-bars"></i></button>
  <div class="sidebar-overlay" id="sidebarOverlay"></div>

  <main class="container my-4" style="margin-top:80px!important">
    <div class="row justify-content-end">
      <div class="col-12 col-md-10 col-lg-9 col-xl-10">
        <div class="card shadow-sm border-0 rounded-4">
          <div class="card-header bg-white fw-bold fs-5"><i class="fas fa-cog me-2"></i>Cài đặt tài khoản</div>
          <div class="card-body">
            
            <!-- Đổi tên hiển thị -->
            <div class="settings-section">
              <h5><i class="fas fa-user-edit me-2"></i>Đổi tên hiển thị</h5>
              <p class="text-muted small">Tên này sẽ hiển thị trên bài viết và bình luận. Tên đăng nhập (<span id="currentUsername"></span>) không thay đổi.</p>
              <form id="renameForm" class="mt-3">
                <div class="mb-2"><input type="text" id="newDisplayName" class="form-control" placeholder="Tên hiển thị mới" required></div>
                <button type="submit" class="btn btn-primary btn-sm">Cập nhật tên hiển thị</button>
                <div id="renameMessage" class="small mt-2"></div>
              </form>
            </div>
            
            <!-- Đổi mật khẩu -->
            <div class="settings-section">
              <h5><i class="fas fa-key me-2"></i>Đổi mật khẩu</h5>
              <form id="changePasswordForm" class="mt-3">
                <div class="mb-2"><input type="password" id="currentPassword" class="form-control" placeholder="Mật khẩu hiện tại" required></div>
                <div class="mb-2"><input type="password" id="newPassword" class="form-control" placeholder="Mật khẩu mới" required></div>
                <div class="mb-2"><input type="password" id="confirmPassword" class="form-control" placeholder="Xác nhận mật khẩu mới" required></div>
                <button type="submit" class="btn btn-warning btn-sm">Đổi mật khẩu</button>
                <div id="passwordMessage" class="small mt-2"></div>
              </form>
            </div>
            
            <!-- Xóa tài khoản -->
            <div class="settings-section">
              <h5><i class="fas fa-trash-alt text-danger me-2"></i>Xoá tài khoản</h5>
              <p class="text-muted small">Xoá tài khoản sẽ xoá tất cả bài viết và bình luận của bạn. Tài khoản sẽ bị xoá vĩnh viễn sau 1 giờ nếu bạn không huỷ.</p>
              <button type="button" id="deleteAccountBtn" class="btn btn-danger btn-sm">Yêu cầu xoá tài khoản</button>
              <div id="deleteStatus" class="small mt-2"></div>
            </div>
            
            <div id="cancelDeleteSection" style="display:none">
              <div class="alert alert-warning">
                <i class="fas fa-clock me-2"></i>Bạn đã yêu cầu xoá tài khoản. Tài khoản sẽ bị xoá sau 1 giờ.
                <button type="button" id="cancelDeleteBtn" class="btn btn-sm btn-outline-warning ms-3">Huỷ yêu cầu</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
  
  <%- include('partials/footer') %>
  
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/common.js"></script>
  <script>

    document.getElementById('renameForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const newDisplayName = document.getElementById('newDisplayName').value.trim();
      if (!newDisplayName || newDisplayName.length < 2) {
        return showToast('Tên phải từ 2-50 ký tự', 'danger');
      }
      const res = await fetch('/settings/rename', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ newDisplayName })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Đã cập nhật tên!', 'success');
        const sidebarDisplayName = document.getElementById('sidebarDisplayName');
        if (sidebarDisplayName) sidebarDisplayName.innerText = newDisplayName;
        setTimeout(() => location.reload(), 1500);
      } else {
        showToast(data.error || 'Lỗi', 'danger');
      }
    });

    // Đổi mật khẩu
    document.getElementById('changePasswordForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const currentPassword = document.getElementById('currentPassword').value;
      const newPassword = document.getElementById('newPassword').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      if (newPassword !== confirmPassword) return showToast('Mật khẩu mới không khớp', 'danger');
      if (newPassword.length < 6) return showToast('Mật khẩu phải có ít nhất 6 ký tự', 'danger');
      
      const res = await fetch('/settings/change-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ currentPassword, newPassword })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Đổi mật khẩu thành công!', 'success');
        document.getElementById('changePasswordForm').reset();
      } else {
        showToast(data.error || 'Sai mật khẩu hiện tại', 'danger');
      }
    });

    // Kiểm tra trạng thái xóa
    async function checkDeleteStatus() {
      const res = await fetch('/settings/delete-status');
      const data = await res.json();
      if (data.pending) {
        document.getElementById('cancelDeleteSection').style.display = 'block';
        document.getElementById('deleteStatus').innerHTML = data.remainingSeconds 
          ? '<span class="text-warning">⏳ Tài khoản sẽ bị xoá sau ' + Math.ceil(data.remainingSeconds / 60) + ' phút</span>' 
          : '';
      } else {
        document.getElementById('cancelDeleteSection').style.display = 'none';
        document.getElementById('deleteStatus').innerHTML = '';
      }
    }
    
    // Yêu cầu xóa tài khoản
    document.getElementById('deleteAccountBtn').addEventListener('click', async () => {
      const password = prompt('Nhập mật khẩu để xác nhận xoá tài khoản:');
      if (!password) return;
      const res = await fetch('/settings/request-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ password })
      });
      const data = await res.json();
      if (data.success) {
        showToast('Xác nhận xoá tài khoản thành công! Tài khoản sẽ bị xoá sau 1 giờ.', 'warning');
        checkDeleteStatus();
      } else {
        showToast(data.error || 'Sai mật khẩu', 'danger');
      }
    });
    
    // Hủy yêu cầu xóa
    document.getElementById('cancelDeleteBtn')?.addEventListener('click', async () => {
      const res = await fetch('/settings/cancel-delete', { method: 'POST' });
      const data = await res.json();
      if (data.success) {
        showToast('Đã huỷ yêu cầu xoá tài khoản', 'success');
        checkDeleteStatus();
      }
    });
    
    checkDeleteStatus();
    setInterval(checkDeleteStatus, 30000);

    // Theme
    const darkCSS = document.getElementById('theme-css');
    const themeSwitch = document.getElementById('themeSwitch');
    const themeIcon = document.getElementById('themeIcon');
    const themeText = document.getElementById('themeText');
    const isDark = localStorage.getItem('theme') === 'dark';
    if (darkCSS) darkCSS.disabled = !isDark;
    if (themeSwitch) themeSwitch.checked = isDark;
    if (themeIcon) themeIcon.className = isDark ? 'fas fa-sun' : 'fas fa-moon';
    if (themeText) themeText.innerText = isDark ? 'Chế độ sáng' : 'Chế độ tối';
    if (themeSwitch) {
      themeSwitch.addEventListener('change', function() {
        const newIsDark = this.checked;
        if (darkCSS) darkCSS.disabled = !newIsDark;
        localStorage.setItem('theme', newIsDark ? 'dark' : 'light');
        if (themeIcon) themeIcon.className = newIsDark ? 'fas fa-sun' : 'fas fa-moon';
        if (themeText) themeText.innerText = newIsDark ? 'Chế độ sáng' : 'Chế độ tối';
      });
    }
  </script>
</body>
</html>