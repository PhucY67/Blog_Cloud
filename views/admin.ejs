<!DOCTYPE html>
<html lang="vi">
<head>
    <% const title = 'Quản trị - BlogCloud'; %>
    <%- include('partials/head', { title: title }) %>
</head>
<body>
    <%- include('partials/header') %>
    <script src="/js/sidebar.js"></script>
    
    <main class="container my-4" style="margin-top: 80px !important;">
    <div class="row justify-content-end">
        <div class="col-12 col-md-10 col-lg-9 col-xl-10">
            
            <div class="mb-3 d-flex gap-2">
                <a href="/admin" class="btn btn-danger"><i class="fas fa-flag"></i> Bài viết bị báo cáo</a>
                <a href="/admin/hidden" class="btn btn-dark"><i class="fas fa-eye-slash"></i> Bài viết đã ẩn</a>
                <a href="/admin/users" class="btn btn-info"><i class="fas fa-users"></i> Quản lý tài khoản</a>
            </div>
            
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-danger text-white fw-bold">
                    <i class="fas fa-flag me-2"></i>Quản trị bài viết vi phạm
                </div>
                <div class="card-body">
                    <% if (posts && posts.length > 0) { %>
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead>
                                <tr>
                                    <th>Tiêu đề</th>
                                    <th>Tác giả</th>
                                    <th>Số báo cáo</th>
                                    <th>Hành động</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% posts.forEach(post => { %>
                                    <tr>
                                        <td>
                                            <a href="/posts/<%= post._id %>"><%= post.title %></a>
                                            <% if (post.tags && post.tags.length > 0) { %>
                                                <div>
                                                    <% post.tags.forEach(t => { %>
                                                        <span class="badge bg-secondary me-1"><%= t %></span>
                                                    <% }) %>
                                                </div>
                                            <% } %>
                                        </td>
                                        <td>
                                            <a href="/users/profile/<%= post.author._id %>" class="text-decoration-none">
                                                <%= post.author ? post.author.username : 'Unknown' %>
                                            </a>
                                        </td>
                                        <td><span class="badge bg-warning text-dark">
                                                <%= post.reports ? post.reports.length : 0 %>
                                            </span></td>
                                        <td>
                                            <form action="/admin/hide/<%= post._id %>" method="POST"
                                                class="d-inline hide-post-form" onsubmit="return confirm('Ẩn bài viết này?')">
                                                <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-eye-slash"></i> Ẩn bài</button>
                                            </form>
                                            <form action="/posts/<%= post._id %>/delete" method="POST"
                                                class="d-inline" onsubmit="return confirm('Xóa vĩnh viễn bài viết này?')">
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fas fa-trash"></i> Xóa</button>
                                            </form>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="fas fa-check-circle text-success fs-1 mb-3"></i>
                            <p class="text-muted">Không có bài viết nào bị báo cáo.</p>
                        </div>
                    <% } %>
                </div>
            </div>
            
        </div>
    </div>
</main>

   <%- include('partials/footer') %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/common.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>